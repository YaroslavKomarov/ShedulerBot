# Telegram
TELEGRAM_BOT_TOKEN=

# OpenRouter (chat completions)
OPENROUTER_API_KEY=

# Voice transcription (Whisper)
# WHISPER_PROVIDER=groq    # groq (default, free 2000 min/day) | openai ($0.006/min)
# WHISPER_LANGUAGE=ru      # ISO 639-1 language code (default: ru) — speeds up & improves accuracy
GROQ_API_KEY=              # required when WHISPER_PROVIDER=groq (default)
# OPENAI_API_KEY=          # required when WHISPER_PROVIDER=openai

# Supabase (shared instance — only touch sch_* tables)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Logging
LOG_LEVEL=info        # debug | info | warn | error

# Runtime
NODE_ENV=development  # development | production
PORT=3000
WEBHOOK_URL=          # required in production (e.g. https://your-domain.com)

# API auth (for external modules, e.g. SoloLeveling)
API_SECRET_KEY=

# SoloLeveling integration (optional — enables period sync during onboarding and /settings)
SOLO_LEVELING_URL=    # e.g. https://your-solo-leveling-domain.com
