# Telegram
TELEGRAM_BOT_TOKEN=

# OpenRouter
OPENROUTER_API_KEY=

# Supabase (shared instance — only touch sch_* tables)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Logging
LOG_LEVEL=info        # debug | info | warn | error

# Runtime
NODE_ENV=development  # development | production
PORT=3000
WEBHOOK_URL=          # required in production (e.g. https://your-domain.com)

# API auth (for external modules, e.g. SoloLeveling)
API_SECRET_KEY=
